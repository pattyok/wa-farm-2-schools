{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"customGradients": false,
			"defaultPalette": false,
			"palette": [

				{
					"color": "#328F41",
					"name": "Green",
					"slug": "primary"
				},
				{
					"color": "#B4CE65",
					"name": "Green Light",
					"slug": "primary-light"
				},
				{
					"color": "#F2F0EA",
					"name": "Beige Light",
					"slug": "tint-lt"
				},
				{
					"color": "#4684BE",
					"name": "Sky Blue",
					"slug": "secondary"
				},
				{
					"color": "#E95234",
					"name": "Bright Orange",
					"slug": "accent"
				},
				{
					"color": "#FFA600",
					"name": "Bright Gold",
					"slug": "accent-2"
				},
				{
					"color": "#0D5B0E",
					"name": "Green Dark",
					"slug": "primary-dark"
				},
				{
					"color": "#0A25A0",
					"name": "Blue Dark",
					"slug": "secondary-dark"
				},
				{
					"color": "#c3c3c3",
					"name": "Grey",
					"slug": "grey"
				},

				{
					"color": "#FFFFFF",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "contrast"
				}
			],
			"gradients": [
				{
					"slug": "green-light-to-dark",
					"gradient": "linear-gradient(90deg, #0D5B0E 0%, #328F41 100%)",
					"name": "Green Gradient"
				}
			]
		},
		"layout": {
			"contentSize": "var(--content-width)",
			"wideSize": "var(--content-width-wide)"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "clamp(30px, 5vw, 35px)",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(30px, 5vw, 50px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(40px, 7vw, 60px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(40px, 7vw, 80px)",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "clamp(70px, 10vw, 100px)",
					"slug": "80"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontSizes": [

				{
					"fluid": {
						"max": "0.9375rem",
						"min": "0.9375rem"
					},
					"name": "Extra Small",
					"size": "0.9375rem",
					"slug": "x-small"
				},
				{
					"fluid": {
						"max": "1rem",
						"min": "1rem"
					},
					"name": "Small",
					"size": "1rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.125rem",
						"min": "1.125rem"
					},
					"name": "Base",
					"size": "1.125rem",
					"slug": "base"
				},
				{
					"fluid": {
						"max": "1.3125rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.3125rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.375rem"
					},
					"name": "Extra Large",
					"size": "1.375rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3.75rem",
						"min": "3.1875rem"
					},
					"name": "Extra Extra Large",
					"size": "3.75rem",
					"slug": "xx-large"
				}
			],
			"fontFamilies": [
				{
					"name": "Poppins",
					"slug": "headings",
					"fontFamily": "'poppins', sans-serif"
				},
				{
					"name": "Lato",
					"slug": "global",
					"fontFamily": "'lato', sans-serif"
				}
			]
		},
		"blocks":{
			"core/heading": {
				"typography": {
					"fontSizes": [
						{
						"slug": "h1",
						"size": "var(--font-size-h1)",
						"name": "H1"
						},
						{
						"slug": "h2",
						"size": "var(--font-size-h2)",
						"name": "H2"
						},
						{
						"slug": "h3",
						"size": "var(--font-size-h3)",
						"name": "H3"
						},
						{
						"slug": "h4",
						"size": "var(--font-size-h4)",
						"name": "H4"
						},
						{
						"slug": "h5",
						"size": "var(--font-size-h5)",
						"name": "H5"
						},
						{
						"slug": "h6",
						"size": "var(--font-size-h6)",
						"name": "H6"
						}
					]
        		}
      		}
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|30"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|global",
			"fontSize": "var:preset|font-size|base",
			"fontWeight": "500",
			"letterSpacing": "0",
			"lineHeight": "1.64"
		},
		"blocks": {
			"core/avatar": {
				"border": {
					"radius": "100px"
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "var:preset|spacing|50"
				}
			},
			"core/column": {
				"spacing": {
					"blockGap": "var:preset|spacing|40"
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "16px"
				}
			},
			"core/social-links": {
				"openInNewTab": true,
				"spacing": {
					"blockGap": {
						"left": "var:preset|spacing|20"
					}
				}
			},
			"core/post-date": {
				"color":{
					"text": "var:preset|color|accent-4"
				},
				"elements": {
					"link": {
						"color" : {
							"text": "var:preset|color|secondary"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							},
							"color" : {
								"text": "var:preset|color|secondary-dark"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/post-navigation-link": {
				"typography": {
					"fontSize": "var:preset|font-size|base"
				}
			},
			"core/post-terms": {
				"css": "& a { white-space: nowrap; }",
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "600"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/group": {
				"spacing": {
					"blockGap": "var:preset|spacing|40"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large",
					"lineHeight": "1.6",
					"textAlign": "left"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var:preset|font-size|small",
							"fontStyle": "normal",
							"textTransform": "none"
						}
					}
				},
				"spacing": {
					"padding": {
						"bottom": "var:preset|spacing|30",
						"top": "var:preset|spacing|30"
					}
				},
				"css": "& p:last-of-type {margin-bottom: var(--wp--preset--spacing--30);}"
			},
			"core/query-pagination": {
				"typography": {
					"fontSize": "var:preset|font-size|base",
					"fontWeight": "500"
				}
			},

			"core/separator": {
				"border": {
					"color": "currentColor",
					"style": "solid",
					"width": "0 0 2px 0"
				},
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|70",
						"bottom": "var:preset|spacing|70"
					}
				},
				"variations": {
					"wide": {
						"css": " &:not(.alignfull){max-width: var(--wp--style--global--wide-size) !important;}"
					}
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontSize": "var:preset|font-size|base"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "700",
					"letterSpacing": "-.5px"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/term-description": {
				"typography": {
					"fontSize": "var:preset|font-size|base"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|base"
				},
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			}
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|accent",
					"text": "var:preset|color|base"
				},
				"border": {
					"radius": "0",
					"color": "currentColor",
					"width": "0",
					"style": "solid"
				},

				"spacing": {
					"padding": {
						"bottom": "1.0625rem",
						"left": "1.875rem",
						"right": "1.875rem",
						"top": "1.0625rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|headings",
					"textTransform": "uppercase",
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "900",
					"letterSpacing": "0.32px"
				},
				":hover":{
					"color": {
						"text": "var:preset|color|base",
						"background": "var:preset|color|accent-2"
					},
					"border": {
						"color": "var:preset|color|accent-2"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"lineHeight": "1.4"
				}
			},

			"link": {
				"color": {
					"text": "var:preset|color|secondary"
				},
				"typography": {
					"textDecoration": "none",
					"fontWeight": "800"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					},
					"color": {
						"text": "var:preset|color|secondary-dark"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "header",
			"name": "vertical-header",
			"title": "Vertical Header"
		},
		{
			"area": "header",
			"name": "header-large-title",
			"title": "Header with large title"

		},
		{
			"area": "footer",
			"name": "site-footer",
			"title": "Site Footer"
		},
		{
			"area": "footer",
			"name": "post-footer",
			"title": "Post Footer"
		},
		{
			"area": "footer",
			"name": "location-footer",
			"title": "Location Footer"
		}

	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"postTypes": ["page"],
			"title": "Page No Title"
		}
	]
}
